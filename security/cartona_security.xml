<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_cartona_user" model="res.groups">
            <field name="name">Cartona User</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="comment">View Cartona integration status</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_cartona_manager" model="res.groups">
            <field name="name">Cartona Manager</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="comment">Configure and manage Cartona integration</field>
            <field name="implied_ids" eval="[(4, ref('group_cartona_user'))]"/>
        </record>

        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('group_cartona_manager'))]"/>
        </record>

        <record id="cartona_config_company_rule" model="ir.rule">
            <field name="name">Cartona Config: multi-company</field>
            <field name="model_id" ref="model_cartona_config"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cartona_sync_log_company_rule" model="ir.rule">
            <field name="name">Cartona Sync Log: multi-company</field>
            <field name="model_id" ref="model_cartona_sync_log"/>
            <field name="domain_force">[('cartona_config_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cartona_sync_log_line_company_rule" model="ir.rule">
            <field name="name">Cartona Sync Log Line: multi-company</field>
            <field name="model_id" ref="model_cartona_sync_log_line"/>
            <field name="domain_force">[('sync_log_id.cartona_config_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cartona_product_sync_company_rule" model="ir.rule">
            <field name="name">Cartona Product Sync: multi-company</field>
            <field name="model_id" ref="model_cartona_product_sync"/>
            <field name="domain_force">[('cartona_config_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
