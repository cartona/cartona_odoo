<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_cartona_user" model="res.groups">
            <field name="name">Cartona User</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="comment">View Cartona integration status</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_cartona_manager" model="res.groups">
            <field name="name">Cartona Manager</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="comment">Configure and manage Cartona integration</field>
            <field name="implied_ids" eval="[(4, ref('group_cartona_user'))]"/>
        </record>

        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('group_cartona_manager'))]"/>
        </record>

    </data>
</odoo>
