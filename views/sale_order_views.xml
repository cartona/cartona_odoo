<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_cartona" model="ir.ui.view">
        <field name="name">sale.order.form.cartona</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_manual_sync_to_cartona" type="object"
                        string="Sync to Cartona"
                        invisible="not is_cartona_order or not cartona_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Cartona" name="cartona" invisible="not is_cartona_order">
                    <group>
                        <group>
                            <field name="cartona_id" readonly="1"/>
                            <field name="cartona_order_number" readonly="1"/>
                            <field name="cartona_status" readonly="1"/>
                            <field name="cartona_sync_status" readonly="1"/>
                        </group>
                        <group>
                            <field name="delivered_by" readonly="1"/>
                            <field name="cartona_payment_method" readonly="1"/>
                            <field name="cartona_sync_date" readonly="1"/>
                            <field name="cartona_error_message" readonly="1"/>
                        </group>
                    </group>
                    <field name="cartona_notes" readonly="1"/>
                </page>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='name']" position="after">
                <field name="cartona_line_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_sales_order_filter_cartona" model="ir.ui.view">
        <field name="name">sale.order.search.cartona</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_sale_orders_filter']" position="after">
                <filter name="filter_cartona_orders" string="Cartona Orders"
                        domain="[('is_cartona_order', '=', True)]"/>
            </xpath>
        </field>
    </record>

</odoo>
