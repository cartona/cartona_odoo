<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_product_form_view_cartona" model="ir.ui.view">
        <field name="name">product.product.form.cartona</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Cartona" name="cartona">
                    <group>
                        <field name="id" string="Internal Product ID" readonly="1"/>
                        <field name="cartona_sync_status" readonly="1"/>
                        <field name="cartona_sync_date" readonly="1"/>
                        <field name="cartona_sync_error" readonly="1"/>
                    </group>
                    <button name="action_manual_cartona_sync" type="object"
                            string="Sync Now" class="btn-primary"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
