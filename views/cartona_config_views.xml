<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cartona_config_list" model="ir.ui.view">
        <field name="name">cartona.config.list</field>
        <field name="model">cartona.config</field>
        <field name="arch" type="xml">
            <list string="Cartona Configurations">
                <field name="warehouse_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="is_cartona_sync_enabled"/>
                <field name="connection_status"/>
                <field name="last_order_pull"/>
                <field name="last_sync_date"/>
                <button name="action_dashboard_recent_activity" type="object"
                        string="Recent Activity" icon="fa-list-alt"/>
                <button name="action_dashboard_log_details" type="object"
                        string="Log Details" icon="fa-file-text-o"/>
            </list>
        </field>
    </record>

    <record id="view_cartona_config_form" model="ir.ui.view">
        <field name="name">cartona.config.form</field>
        <field name="model">cartona.config</field>
        <field name="arch" type="xml">
            <form string="Cartona Configuration" duplicate="false">
                <header>
                    <button name="test_connection" type="object" string="Test Connection" class="btn-primary"/>
                    <button name="manual_pull_orders" type="object" string="Pull Orders"
                            invisible="not is_cartona_sync_enabled"/>
                    <button name="manual_sync_all_variants" type="object" string="Sync All Variants"
                            invisible="not is_cartona_sync_enabled"/>
                    <button name="action_open_dashboard" type="object" string="Open Dashboard"
                            invisible="not id"/>
                    <field name="connection_status" widget="statusbar"
                           statusbar_visible="not_tested,connected,error"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Sync Disabled"
                            bg_color="text-bg-warning"
                            invisible="is_cartona_sync_enabled"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_synced_variants" type="object"
                                class="oe_stat_button" icon="fa-cubes" invisible="not id">
                            <field name="total_products_synced" widget="statinfo" string="Synced Variants"/>
                        </button>
                        <button name="action_view_cartona_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart" invisible="not id">
                            <field name="total_orders_pulled" widget="statinfo" string="Cartona Orders"/>
                        </button>
                        <button name="action_dashboard_recent_activity" type="object"
                                class="oe_stat_button" icon="fa-list-alt" invisible="not id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Recent Activity</span>
                            </div>
                        </button>
                        <button name="action_dashboard_log_details" type="object"
                                class="oe_stat_button" icon="fa-file-text-o" invisible="not id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Log Details</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Connection">
                            <field name="warehouse_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="name"/>
                            <field name="api_base_url"/>
                            <field name="auth_token" password="True"
                                   groups="cartona_odoo.group_cartona_manager"/>
                            <field name="is_cartona_sync_enabled"/>
                        </group>
                        <group string="Status">
                            <field name="last_sync_date" readonly="1"/>
                            <field name="last_order_pull" readonly="1"/>
                            <field name="error_message" readonly="1" invisible="not error_message"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Advanced">
                            <group>
                                <field name="batch_size"/>
                                <field name="timeout"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cartona_config_list" model="ir.actions.act_window">
        <field name="name">Cartona Configurations</field>
        <field name="res_model">cartona.config</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_cartona_config_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_cartona_config_form')}),
        ]"/>
        <field name="target">current</field>
    </record>

</odoo>
