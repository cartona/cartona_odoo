<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_cartona" model="ir.ui.view">
        <field name="name">stock.picking.form.cartona</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_fill_move_quantity_with_demand" type="object"
                        string="Auto-Fill Quantities"
                        invisible="picking_type_code != 'outgoing'"/>
            </xpath>
        </field>
    </record>

</odoo>
