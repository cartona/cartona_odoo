<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cartona_delivery_otp_wizard_form" model="ir.ui.view">
        <field name="name">cartona.delivery.otp.wizard.form</field>
        <field name="model">cartona.delivery.otp.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter Retailer OTP">
                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="cartona_delivery_otp"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
